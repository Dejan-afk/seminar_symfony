{% extends 'base.html.twig' %}

{% block body %}
<h1>Login</h1>

{% if error %}
    <div>{{ error.messageKey }}</div>
{% endif %}

<div class="container py-4">
    <form method="post">
        <input type="email" name="_username" value="{{ last_username }}" placeholder="Email" required>
        <input type="password" name="_password" placeholder="Password" required>

        <button type="submit">Login</button>
    </form>
</div>

{% endblock %}