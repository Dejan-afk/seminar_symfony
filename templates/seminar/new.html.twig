{% extends 'base.html.twig' %}

{% block body %}
    <h1>Neues Seminar erstellen</h1>

    {% for message in app.flashes('success') %}
        <div>{{ message }}</div>
    {% endfor %}

    {{ form_start(form) }}
        {{ form_row(form.title) }}
        {{ form_row(form.description) }}
        {{ form_row(form.startDate) }}
        {{ form_row(form.endDate) }}
        {{ form_row(form.registrationDeadline) }}
        {{ form_row(form.maxParticipants) }}

        <h2>Sessions</h2>

        {% for sessionForm in form.sessions %}
            <div style="margin-bottom: 1rem; padding: 1rem; border: 1px solid #ccc;">
                {{ form_row(sessionForm.title) }}
                {{ form_row(sessionForm.startsAt) }}
                {{ form_row(sessionForm.endsAt) }}
            </div>
        {% endfor %}

        <button type="submit">Speichern</button>
    {{ form_end(form) }}
{% endblock %}