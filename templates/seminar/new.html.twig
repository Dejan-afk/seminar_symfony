{% extends 'base.html.twig' %}

{% set sessionPrototype %}
    <div class="session-row card mb-3 p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                {{ form_row(form.sessions.vars.prototype.title) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.sessions.vars.prototype.startsAt) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.sessions.vars.prototype.endsAt) }}
            </div>
        </div>
    </div>
{% endset %}

{% block body %}
    <div class="container py-5">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-4">Neues Seminar erstellen</h1>
            <a href="{{ path('seminar_index')}}"
                class="btn btn-sm btn-outline-primary">
                Zurück
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {{ form_start(form) }}

            {{ form_row(form.title) }}
            {{ form_row(form.description) }}
            {{ form_row(form.startDate) }}
            {{ form_row(form.endDate) }}
            {{ form_row(form.registrationDeadline) }}
            {{ form_row(form.maxParticipants) }}

            <h2 class="mt-5 mb-3">Sessions</h2>

            <div
                id="sessions-collection"
                data-index="{{ form.sessions|length }}"
                data-prototype="{{ sessionPrototype|e('html_attr') }}"
            >
                {% for sessionForm in form.sessions %}
                    <div class="session-row card mb-3 p-3">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                {{ form_row(sessionForm.title) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(sessionForm.startsAt) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(sessionForm.endsAt) }}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <button type="button" id="add-session" class="btn btn-outline-secondary">
                +
            </button>

            <button class="btn btn-primary">Speichern</button>

        {{ form_end(form) }}
    </div>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const collection = document.getElementById('sessions-collection');
        const addButton = document.getElementById('add-session');

        if (!collection || !addButton) {
            return;
        }

        addButton.addEventListener('click', () => {
            const index = collection.dataset.index;
            const prototype = collection.dataset.prototype;
            const newForm = prototype.replace(/__name__/g, index);

            collection.insertAdjacentHTML('beforeend', newForm);
            collection.dataset.index = Number(index) + 1;
        });
    });
</script>
{% endblock %}